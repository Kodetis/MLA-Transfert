---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import MessageDisplay from '../../components/MessageDisplay';

const { id } = Astro.params;
---

<Layout title="MLA-Share — Message sécurisé">
  <div class="animate-slide-up space-y-8">

    <div class="text-center space-y-3">
      <h2 class="text-4xl font-bold tracking-tight">
        Message <span class="text-gradient">sécurisé</span> reçu
      </h2>
      <p class="max-w-sm mx-auto leading-relaxed" style="color:var(--text-2)">
        Votre message n'a transité que chiffré. Seul votre navigateur détenait la clé.
      </p>
    </div>

    <div class="card p-8">
      <MessageDisplay id={id!} client:load />
    </div>

  </div>
</Layout>
